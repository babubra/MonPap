# ПРИМЕР PRODUCTION-КОНФИГУРАЦИИ
# Скопируй этот файл в .env и заполни реальными данными.

# База данных
POSTGRES_USER=monpap_user
POSTGRES_PASSWORD=generate_a_secure_password_here
POSTGRES_DB=monpap

# Бэкенд и Секреты
# Сгенерируй надежный секрет: openssl rand -hex 32
JWT_SECRET=generate_a_very_secure_secret_here
DATABASE_URL=postgresql+asyncpg://monpap_user:generate_a_secure_password_here@db:5432/monpap
ALLOWED_EMAILS=your.email@example.com,another.user@example.com
DEV_MODE=false

# Gemini AI API
GEMINI_API_KEY=your_gemini_api_key_here
# Прокси для обхода геоблокировки Google API (оставь пустым если не нужен)
# Формат: http://user:password@host:port
GEMINI_PROXY=

# Настройки SMTP для Magic Link
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your-email@yandex.ru
SMTP_PASSWORD=your_app_password
SMTP_FROM="MonPap <your-email@yandex.ru>"
