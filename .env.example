# === База данных ===
POSTGRES_USER=monpap
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=monpap
DATABASE_URL=postgresql+asyncpg://monpap:changeme_strong_password@db:5432/monpap

# === Для dev.sh (локальная разработка) ===
DATABASE_URL_DEV=postgresql+asyncpg://monpap:changeme_strong_password@localhost:5432/monpap

# === Безопасность ===
JWT_SECRET=changeme_jwt_secret_key_min_32_chars!!
ALLOWED_EMAILS=your@email.com

# === Gemini AI ===
GEMINI_API_KEY=your_gemini_api_key_here

# === SMTP (для Magic Link) ===
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your@domain.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=your@domain.com

# === Режим разработки ===
DEV_MODE=false
